{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "launch-party-queue",
	"compatibility_date": "2025-04-04",
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "launch-party-queue",
			"migrations_dir": "migrations"
		}
	]
}