{
  "name": "launch-party-queue",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "react-router build && vite preview",
    "deploy": "react-router build && wrangler deploy && wrangler d1 migrations apply launch-party-queue --remote",
    "cf-typegen": "wrangler types",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "db:migrate:local": "wrangler d1 migrations apply launch-party-queue --local",
    "db:migrate:remote": "wrangler d1 migrations apply launch-party-queue --remote",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "canvas-confetti": "^1.9.3",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.75.0"
  }
}
